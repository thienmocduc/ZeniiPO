# ═══════════════════════════════════════════════════════════════
# ZENIIPO v1.0 · Environment Variables Template
# Copy này thành `.env.local` và paste giá trị thực
# KHÔNG commit .env.local — đã gitignored
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────
# Settings → API trong Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic Claude ─────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-

# ─── Stripe ───────────────────────────────────────────────────
# Test mode đầu: sk_test_ / pk_test_
# Live mode sau: sk_live_ / pk_live_
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe price IDs (tạo sau khi có 4 products)
STRIPE_PRICE_EXPLORER=price_
STRIPE_PRICE_PRO=price_
STRIPE_PRICE_ELITE=price_
STRIPE_PRICE_ENTERPRISE=price_

# ─── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_
RESEND_FROM_EMAIL=noreply@zeniipo.com

# ─── Rate Limit (Upstash Redis) ──────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Monitoring (Sentry) ─────────────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Zeniipo

# ─── OAuth (Optional) ────────────────────────────────────────
# Q3/2026: Zeni Identity SSO
# NEXT_PUBLIC_ZENI_IDENTITY_URL=https://identity.zenidigital.com
# ZENI_IDENTITY_SECRET=
