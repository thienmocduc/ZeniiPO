# ═══════════════════════════════════════════════════════════════
# ZENICLOUD.IO · Environment Variables Template
# Copy this to `.env.local` and paste real values
# DO NOT commit .env.local — already gitignored
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────
# Settings → API in Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API (used by ops scripts only — NOT shipped to client)
SUPABASE_ACCESS_TOKEN=sbp_
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# Direct Postgres connection (for migrations + backtest scripts)
DATABASE_DIRECT_URL=postgresql://postgres:PASS@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASS@aws-0-REGION.pooler.supabase.com:6543/postgres

# ─── Anthropic Claude (Council of 9 + 108 Agents + NLQ) ──────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-

# ─── Stripe (5-tier subscription) ────────────────────────────
# Test first: sk_test_ / pk_test_  · Live later: sk_live_ / pk_live_
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
# Price IDs — create 4 paid products in Stripe dashboard, paste price_xxx here
STRIPE_PRICE_EXPLORER=price_
STRIPE_PRICE_PRO=price_
STRIPE_PRICE_ELITE=price_
STRIPE_PRICE_ENTERPRISE=price_

# ─── Email (Resend transactional) ────────────────────────────
# https://resend.com/api-keys  · verify domain zenicloud.io first
RESEND_API_KEY=re_
RESEND_FROM=Zeniipo <noreply@zenicloud.io>

# ─── Rate Limit (Upstash Redis) ──────────────────────────────
# https://console.upstash.com/redis  · free tier OK
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ─── Slack notifications (Incoming Webhook) ──────────────────
# Workspace → Apps → Incoming Webhooks → New webhook → choose channel.
# Empty value = no-op (notifications skipped silently).
SLACK_WEBHOOK_URL=

# ─── Google OAuth SSO ────────────────────────────────────────
# Set CLIENT_ID + CLIENT_SECRET in Supabase Dashboard → Auth → Providers → Google
# (NOT in this .env — Supabase Auth holds them server-side).
# Authorized redirect URI: https://moduqdlwgbmvlwiiicqp.supabase.co/auth/v1/callback
# Then enable provider via Supabase Mgmt API or dashboard toggle.

# ─── Monitoring (Sentry) ─────────────────────────────────────
# https://sentry.io → New Project → Next.js
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://zenicloud.io
NEXT_PUBLIC_SITE_NAME=Zeniipo

# ─── Namecheap (DNS automation, ops only) ────────────────────
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
