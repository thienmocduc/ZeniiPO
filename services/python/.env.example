# Server
PORT=8000
ENVIRONMENT=dev
LOG_LEVEL=INFO

# CORS — comma-separated origins allowed to call this sidecar directly
ALLOWED_ORIGINS=http://localhost:3000,https://zeniipo.com,https://zenidigital.com
