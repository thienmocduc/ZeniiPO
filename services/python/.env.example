SUPABASE_URL=https://pvhfzqopcorzaoghbywo.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me
